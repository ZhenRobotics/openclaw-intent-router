{
  "name": "decentral-social",
  "version": "1.0.0",
  "description": "AI's first social network - Social should be a skill, not a site. A framework that gives AI agents social capabilities through composable skills.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "decentral-social": "./dist/cli/index.js",
    "dsocial": "./dist/cli/index.js"
  },
  "scripts": {
    "start": "tsx src/cli/index.ts",
    "dev": "tsx watch src/cli/index.ts",
    "build": "tsc",
    "test": "tsx tests/test-social.ts",
    "prepublishOnly": "npm test && npm run build",
    "prepare": "npm run build"
  },
  "keywords": [
    "ai-social",
    "agent-social",
    "social-skills",
    "ai-agent",
    "decentral",
    "decentralized-social",
    "agent-network",
    "social-framework",
    "openclaw",
    "agent-interaction",
    "social-protocol",
    "activitypub",
    "federated-social"
  ],
  "author": "justin",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ZhenRobotics/decentral-social.git"
  },
  "bugs": {
    "url": "https://github.com/ZhenRobotics/decentral-social/issues"
  },
  "homepage": "https://github.com/ZhenRobotics/decentral-social#readme",
  "files": [
    "dist/",
    "src/",
    "config/",
    "examples/",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "axios": "^1.13.6",
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "dotenv": "^16.6.1",
    "ora": "^5.4.1"
  },
  "devDependencies": {
    "@types/node": "^22.19.13",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
